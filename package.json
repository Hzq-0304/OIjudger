{
  "name": "oijudge",
  "displayName": "OI Judge",
  "description": "Local OI sample judge for VS Code with custom checkers, File IO, and runtime diagnostics.",
  "version": "0.4.0",
  "publisher": "Hzq",
  "icon": "resources/icons/icon.png",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "oi",
    "competitive-programming",
    "judge",
    "checker",
    "testlib",
    "cpp",
    "vscode"
  ],
  "activationEvents": [
    "onCommand:oijudger.initProblem",
    "onCommand:oijudger.addSample",
    "onCommand:oijudger.runAllSamples",
    "onCommand:oijudger.setTimeLimit",
    "onCommand:oijudger.setMemoryLimit",
    "onCommand:oijudger.setStackSize",
    "onCommand:oijudger.selectCompiler",
    "onCommand:oijudger.openLastReport",
    "onCommand:oijudger.openResultPanel",
    "onCommand:oijudger.openSampleDetail",
    "onCommand:oijudger.clearOutputs",
    "onCommand:oijudger.refreshView",
    "onCommand:oijudger.createProblem",
    "onCommand:oijudger.addProblemFromCurrentFile",
    "onCommand:oijudger.addProblemFromFile",
    "onCommand:oijudger.importLegacyProblem",
    "onCommand:oijudger.addProblemSample",
    "onCommand:oijudger.addProblemSampleFromFiles",
    "onCommand:oijudger.batchAddSamples",
    "onCommand:oijudger.runProblemSamples",
    "onCommand:oijudger.runSamplesWithProgram",
    "onCommand:oijudger.setProblemTimeLimit",
    "onCommand:oijudger.setProblemMemoryLimit",
    "onCommand:oijudger.setProblemStackSize",
    "onCommand:oijudger.setJudgeMode",
    "onCommand:oijudger.setIoMode",
    "onCommand:oijudger.setFileIoNames",
    "onCommand:oijudger.setProblemStandard",
    "onCommand:oijudger.selectProblemCompiler",
    "onCommand:oijudger.bindStatement",
    "onCommand:oijudger.openStatement",
    "onCommand:oijudger.unbindStatement",
    "onCommand:oijudger.addProgramToProblem",
    "onCommand:oijudger.setDefaultProgram",
    "onCommand:oijudger.openProblemResultPanel",
    "onCommand:oijudger.openProblemSampleDetail",
    "onCommand:oijudger.openSampleInput",
    "onCommand:oijudger.openSampleAnswer",
    "onCommand:oijudger.openSampleOutput",
    "onCommand:oijudger.openSampleUserOutput",
    "onCommand:oijudger.openSampleDiff",
    "onCommand:oijudger.deleteSample",
    "onView:oijudger.samplesView",
    "onCommand:oijudger.setChecker",
    "onCommand:oijudger.setPlainCheckerProtocol",
    "onCommand:oijudger.clearChecker",
    "onCommand:oijudger.openChecker",
    "onCommand:oijudger.importTestlib",
    "onCommand:oijudger.openTestlib",
    "onCommand:oijudger.openCheckerOutput",
    "onCommand:oijudger.selectStdProgram",
    "onCommand:oijudger.openStdProgram",
    "onCommand:oijudger.clearStdProgram",
    "onCommand:oijudger.setSampleName"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hzq-0304/OIjudge.git"
  },
  "license": "MIT",
  "contributes": {
    "commands": [
      {
        "command": "oijudger.initProblem",
        "title": "OI Judge: Init Problem",
        "icon": "$(repo-create)"
      },
      {
        "command": "oijudger.addSample",
        "title": "OI Judge: Add Sample",
        "icon": "$(add)"
      },
      {
        "command": "oijudger.runAllSamples",
        "title": "OI Judge: Run All Samples",
        "icon": "$(run-all)"
      },
      {
        "command": "oijudger.setTimeLimit",
        "title": "OI Judge: Set Time Limit",
        "icon": "$(watch)"
      },
      {
        "command": "oijudger.setMemoryLimit",
        "title": "OI Judge: Set Memory Limit",
        "icon": "$(server)"
      },
      {
        "command": "oijudger.setStackSize",
        "title": "OI Judge: 设置栈空间/Set Stack Size",
        "icon": "$(layers)"
      },
      {
        "command": "oijudger.selectCompiler",
        "title": "OI Judge: Select C++ Compiler",
        "icon": "$(settings-gear)"
      },
      {
        "command": "oijudger.openLastReport",
        "title": "OI Judge: Open Last Report",
        "icon": "$(preview)"
      },
      {
        "command": "oijudger.openResultPanel",
        "title": "OI Judge: Open Result Panel",
        "icon": "$(layout-panel)"
      },
      {
        "command": "oijudger.openSampleDetail",
        "title": "OI Judge: Open Sample Detail",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.clearOutputs",
        "title": "OI Judge: Clear Outputs",
        "icon": "$(trash)"
      },
      {
        "command": "oijudger.refreshView",
        "title": "OI Judge: Refresh View",
        "icon": "$(refresh)"
      },
      {
        "command": "oijudger.createProblem",
        "title": "OI Judge: 创建题目/Create Problem",
        "icon": "$(new-folder)"
      },
      {
        "command": "oijudger.addProblemFromCurrentFile",
        "title": "OI Judge: Add Problem From Current File",
        "icon": "$(file-code)"
      },
      {
        "command": "oijudger.addProblemFromFile",
        "title": "OI Judge: Add Problem From File",
        "icon": "$(file-add)"
      },
      {
        "command": "oijudger.importLegacyProblem",
        "title": "OI Judge: Import Legacy Single Problem",
        "icon": "$(repo-pull)"
      },
      {
        "command": "oijudger.addProblemSample",
        "title": "OI Judge: Add Problem Sample",
        "icon": "$(add)"
      },
      {
        "command": "oijudger.addProblemSampleFromFiles",
        "title": "OI Judge: Add Problem Sample From Files",
        "icon": "$(file-add)"
      },
      {
        "command": "oijudger.batchAddSamples",
        "title": "OI Judge: 批量添加样例/Batch Add Samples",
        "icon": "$(folder-opened)"
      },
      {
        "command": "oijudger.runProblemSamples",
        "title": "OI Judge: Run Problem Samples",
        "icon": "$(run-all)"
      },
      {
        "command": "oijudger.runSamplesWithProgram",
        "title": "OI Judge: 选择程序评测/Run With Program",
        "icon": "$(run)"
      },
      {
        "command": "oijudger.setProblemTimeLimit",
        "title": "OI Judge: Set Problem Time Limit",
        "icon": "$(watch)"
      },
      {
        "command": "oijudger.setProblemMemoryLimit",
        "title": "OI Judge: Set Problem Memory Limit",
        "icon": "$(server)"
      },
      {
        "command": "oijudger.setProblemStackSize",
        "title": "OI Judge: Set Problem Stack Size",
        "icon": "$(layers)"
      },
      {
        "command": "oijudger.setJudgeMode",
        "title": "OI Judge: 设置评测方式/Set Judge Mode",
        "icon": "$(diff)"
      },
      {
        "command": "oijudger.setIoMode",
        "title": "OI Judge: 设置输入输出方式/Set I/O Mode",
        "icon": "$(terminal)"
      },
      {
        "command": "oijudger.setFileIoNames",
        "title": "OI Judge: 设置文件输入输出文件名/Set File I/O Names",
        "icon": "$(files)"
      },
      {
        "command": "oijudger.setProblemStandard",
        "title": "OI Judge: Set Problem C++ Standard",
        "icon": "$(settings)"
      },
      {
        "command": "oijudger.selectProblemCompiler",
        "title": "OI Judge: Select Problem Compiler",
        "icon": "$(settings-gear)"
      },
      {
        "command": "oijudger.bindStatement",
        "title": "OI Judge: 绑定题面/Bind Statement",
        "icon": "$(link)"
      },
      {
        "command": "oijudger.openStatement",
        "title": "OI Judge: 打开题面/Open Statement",
        "icon": "$(book)"
      },
      {
        "command": "oijudger.unbindStatement",
        "title": "OI Judge: 解绑题面/Unbind Statement",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "oijudger.addProgramToProblem",
        "title": "OI Judge: 添加程序/Add Program",
        "icon": "$(file-add)"
      },
      {
        "command": "oijudger.setDefaultProgram",
        "title": "OI Judge: 设置默认程序/Set Default Program",
        "icon": "$(star-full)"
      },
      {
        "command": "oijudger.openProblemResultPanel",
        "title": "OI Judge: Open Problem Result Panel",
        "icon": "$(layout-panel)"
      },
      {
        "command": "oijudger.openProblemSampleDetail",
        "title": "OI Judge: Open Problem Sample Detail",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.openSampleInput",
        "title": "OI Judge: Open Sample Input",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.openSampleAnswer",
        "title": "OI Judge: Open Expected Output",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.openSampleOutput",
        "title": "OI Judge: Open Run Result",
        "icon": "$(output)"
      },
      {
        "command": "oijudger.openSampleUserOutput",
        "title": "OI Judge: Open Run Result",
        "icon": "$(output)"
      },
      {
        "command": "oijudger.openSampleDiff",
        "title": "OI Judge: Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "oijudger.deleteSample",
        "title": "OI Judge: 删除样例/Delete Sample",
        "icon": "$(trash)"
      },
      {
        "command": "oijudger.setChecker",
        "title": "OI Judge: 设置 Checker/Set Checker",
        "icon": "$(verified)"
      },
      {
        "command": "oijudger.setPlainCheckerProtocol",
        "title": "OI Judge: 设置 Plain Checker 协议/Set Plain Checker Protocol",
        "icon": "$(settings)"
      },
      {
        "command": "oijudger.clearChecker",
        "title": "OI Judge: 清除 Checker/Clear Checker",
        "icon": "$(clear-all)"
      },
      {
        "command": "oijudger.openChecker",
        "title": "OI Judge: 打开 Checker/Open Checker",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.importTestlib",
        "title": "OI Judge: 导入 testlib.h/Import testlib.h",
        "icon": "$(cloud-download)"
      },
      {
        "command": "oijudger.openTestlib",
        "title": "OI Judge: 打开 testlib.h/Open testlib.h",
        "icon": "$(book)"
      },
      {
        "command": "oijudger.openCheckerOutput",
        "title": "OI Judge: Open Checker Output",
        "icon": "$(output)"
      },
      {
        "command": "oijudger.selectStdProgram",
        "title": "OI Judge: 选择 STD/Select STD",
        "icon": "$(file-code)"
      },
      {
        "command": "oijudger.openStdProgram",
        "title": "OI Judge: 打开 STD/Open STD",
        "icon": "$(go-to-file)"
      },
      {
        "command": "oijudger.clearStdProgram",
        "title": "OI Judge: 清除 STD/Clear STD",
        "icon": "$(clear-all)"
      },
      {
        "command": "oijudger.setSampleName",
        "title": "OI Judge: 设置样例名称/Set Sample Name",
        "icon": "$(tag)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oijudger",
          "title": "OI Judge",
          "icon": "resources/icons/activitybar.svg"
        }
      ]
    },
    "views": {
      "oijudger": [
        {
          "id": "oijudger.samplesView",
          "name": "OI Judge"
        }
      ]
    },
    "configuration": {
      "title": "OI Judge",
      "properties": {
        "oijudger.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh"
          ],
          "enumDescriptions": [
            "Follow VSCode display language.",
            "Use English UI text.",
            "Use Chinese UI text."
          ],
          "description": "Controls OI Judge UI language."
        },
        "oijudger.setterMode.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When enabled, OI Judge shows problem setter tools such as selecting the standard solution, maintaining sample names, and managing data configuration."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "oijudger.createProblem",
          "when": "view == oijudger.samplesView",
          "group": "navigation@0"
        },
        {
          "command": "oijudger.addProblemFromCurrentFile",
          "when": "view == oijudger.samplesView",
          "group": "navigation@1"
        },
        {
          "command": "oijudger.addProblemFromFile",
          "when": "view == oijudger.samplesView",
          "group": "navigation@2"
        },
        {
          "command": "oijudger.importLegacyProblem",
          "when": "view == oijudger.samplesView",
          "group": "navigation@3"
        },
        {
          "command": "oijudger.refreshView",
          "when": "view == oijudger.samplesView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "oijudger.setJudgeMode",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "0_judge"
        },
        {
          "command": "oijudger.setIoMode",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "0_judge@2"
        },
        {
          "command": "oijudger.bindStatement",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "1_statement"
        },
        {
          "command": "oijudger.openStatement",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "1_statement"
        },
        {
          "command": "oijudger.unbindStatement",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "1_statement"
        },
        {
          "command": "oijudger.addProgramToProblem",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "2_program"
        },
        {
          "command": "oijudger.batchAddSamples",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "2_samples"
        },
        {
          "command": "oijudger.runSamplesWithProgram",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "3_run"
        },
        {
          "command": "oijudger.runProblemSamples",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker)",
          "group": "3_run"
        },
        {
          "command": "oijudger.openSampleInput",
          "when": "view == oijudger.samplesView && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker || viewItem == sampleMissing)",
          "group": "inline@1"
        },
        {
          "command": "oijudger.openSampleAnswer",
          "when": "view == oijudger.samplesView && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker || viewItem == sampleMissing)",
          "group": "inline@2"
        },
        {
          "command": "oijudger.openSampleUserOutput",
          "when": "view == oijudger.samplesView && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker)",
          "group": "inline@3"
        },
        {
          "command": "oijudger.openSampleDiff",
          "when": "view == oijudger.samplesView && (viewItem == sampleWa || viewItem == sampleWaChecker)",
          "group": "inline@5"
        },
        {
          "command": "oijudger.deleteSample",
          "when": "view == oijudger.samplesView && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker || viewItem == sampleMissing)",
          "group": "inline@9"
        },
        {
          "command": "oijudger.deleteSample",
          "when": "view == oijudger.samplesView && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker || viewItem == sampleMissing)",
          "group": "9_delete"
        },
        {
          "command": "oijudger.setChecker",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "3_checker@1"
        },
        {
          "command": "oijudger.setPlainCheckerProtocol",
          "when": "view == oijudger.samplesView && viewItem == oijudgerProblemPlainChecker",
          "group": "3_checker@1.5"
        },
        {
          "command": "oijudger.clearChecker",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "3_checker@2"
        },
        {
          "command": "oijudger.openChecker",
          "when": "view == oijudger.samplesView && (viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "3_checker@3"
        },
        {
          "command": "oijudger.importTestlib",
          "when": "view == oijudger.samplesView && viewItem == oijudgerProblemChecker",
          "group": "3_checker@4"
        },
        {
          "command": "oijudger.openTestlib",
          "when": "view == oijudger.samplesView && viewItem == oijudgerProblemChecker",
          "group": "3_checker@5"
        },
        {
          "command": "oijudger.openCheckerOutput",
          "when": "view == oijudger.samplesView && (viewItem == sampleChecker || viewItem == sampleWaChecker)",
          "group": "inline@6"
        },
        {
          "command": "oijudger.setSampleName",
          "when": "view == oijudger.samplesView && oijudger.setterModeEnabled && (viewItem == sample || viewItem == sampleChecker || viewItem == sampleWa || viewItem == sampleWaChecker || viewItem == sampleMissing)",
          "group": "8_setter"
        },
        {
          "command": "oijudger.selectStdProgram",
          "when": "view == oijudger.samplesView && oijudger.setterModeEnabled && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "4_setter@1"
        },
        {
          "command": "oijudger.openStdProgram",
          "when": "view == oijudger.samplesView && oijudger.setterModeEnabled && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "4_setter@2"
        },
        {
          "command": "oijudger.clearStdProgram",
          "when": "view == oijudger.samplesView && oijudger.setterModeEnabled && (viewItem == oijudgerProblemNormal || viewItem == oijudgerProblemChecker || viewItem == oijudgerProblemPlainChecker)",
          "group": "4_setter@3"
        }
      ],
      "commandPalette": [
        {
          "command": "oijudger.openSampleDetail",
          "when": "false"
        },
        {
          "command": "oijudger.addProblemSample",
          "when": "false"
        },
        {
          "command": "oijudger.addProblemSampleFromFiles",
          "when": "false"
        },
        {
          "command": "oijudger.runProblemSamples",
          "when": "false"
        },
        {
          "command": "oijudger.setProblemTimeLimit",
          "when": "false"
        },
        {
          "command": "oijudger.setProblemMemoryLimit",
          "when": "false"
        },
        {
          "command": "oijudger.setProblemStackSize",
          "when": "false"
        },
        {
          "command": "oijudger.setFileIoNames",
          "when": "false"
        },
        {
          "command": "oijudger.setProblemStandard",
          "when": "false"
        },
        {
          "command": "oijudger.selectProblemCompiler",
          "when": "false"
        },
        {
          "command": "oijudger.openProblemResultPanel",
          "when": "false"
        },
        {
          "command": "oijudger.openProblemSampleDetail",
          "when": "false"
        },
        {
          "command": "oijudger.openSampleInput",
          "when": "false"
        },
        {
          "command": "oijudger.openSampleAnswer",
          "when": "false"
        },
        {
          "command": "oijudger.openSampleOutput",
          "when": "false"
        },
        {
          "command": "oijudger.openSampleUserOutput",
          "when": "false"
        },
        {
          "command": "oijudger.openSampleDiff",
          "when": "false"
        },
        {
          "command": "oijudger.openCheckerOutput",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.87.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
